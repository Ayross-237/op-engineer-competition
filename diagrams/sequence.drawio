                <mxCell id="m1" value="&lt;font style=&quot;font-size: 14px;&quot;&gt;1.  Look up everything we need about this school&lt;/font&gt;" style="endArrow=block;html=1;strokeColor=#82b366;strokeWidth=2;fontSize=13;labelBackgroundColor=#ffffff;verticalAlign=bottom;" edge="1" parent="1">
